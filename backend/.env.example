# AdaptiveRAG v0 – copy to .env and adjust as needed

# Data directory (default: backend/data)
# ADAPTIVERAG_DATA_DIR=./data

# Embedding provider: hash (default, no deps) or sbert (requires sentence-transformers)
EMBEDDING_PROVIDER=hash

# Generation: extractive (default, no LLM) or ollama (local LLM)
# GENERATION_PROVIDER=extractive
GENERATION_PROVIDER=ollama

# Ollama configuration (only when GENERATION_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
# Model: qwen2.5:3b (good for 8GB RAM), llama3.1:8b (good for 16GB+ RAM)
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_TOKENS=512
OLLAMA_TEMPERATURE=0.2
# DEBUG_STORE_FULL_PROMPT=0

# Chunking
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=200

# CORS origins for frontend dev (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
